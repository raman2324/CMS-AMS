# Environment variables — never commit secrets
.env

# SQLite database — each dev runs their own migrations
db.sqlite3

# Python bytecode
__pycache__/
*.py[cod]
*.pyo

# Django collected static files — generated by collectstatic
staticfiles/

# Generated PDFs — runtime output, not source
local_pdfs/

# Document folders generated at runtime by seed/generate (go to MinIO in production)
documents/Offer Letter/
documents/Salary Letter/
documents/No Objection Certificate/
documents/Experience Certificate/

# Claude Code local settings — machine-specific permissions
.claude/settings.local.json

# Virtual environment — local Python packages, never commit
venv/

# Log files
*.log
server.log

# Common OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.gstack/
