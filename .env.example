# Copy this to .env and fill in values for local dev outside Docker

DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Encryption (REQUIRED for production) ---
# Encrypts all PDF/upload files at rest AND sensitive DB columns (salary, variables).
# Generate a key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: Back this key up securely. Losing it means losing access to all encrypted data.
# WARNING: Never commit the actual key to version control.
DOCUMENT_ENCRYPTION_KEY=your-fernet-key-here

# --- Database ---
# SQLite (default — no further config needed)
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# PostgreSQL (switch by setting these 5 vars):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=cms_db
# DB_USER=cms_user
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432

# --- File Storage ---
# Local filesystem (default, DEBUG=True)
# Nothing to set — files go to local_pdfs/

# S3 / MinIO (set DEBUG=False and configure these):
# AWS_STORAGE_BUCKET_NAME=your-bucket
# AWS_S3_REGION_NAME=ap-south-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_ENDPOINT_URL=http://localhost:9000   # remove for real S3
