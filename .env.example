# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Docker uses postgres URL below; local dev falls back to SQLite if not set
DATABASE_URL=postgres://ams:ams_password@db:5432/ams

# PostgreSQL credentials (used by the docker-compose db service)
POSTGRES_DB=ams
POSTGRES_USER=ams
POSTGRES_PASSWORD=ams_password

# Email
DEFAULT_FROM_EMAIL=noreply@bv.com
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
